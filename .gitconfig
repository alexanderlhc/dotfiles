[user]
	email = alexanderlhc@disroot.org
	name = Alexander Christensen
[init]
	defaultBranch = main
# Custom subcommands: ~/.local/bin/git-*  (auto-discovered via PATH)
[core]
	editor = nvim
[push]
	autoSetupRemote = true
[rerere]
	enabled = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
